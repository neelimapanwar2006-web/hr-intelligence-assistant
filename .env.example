# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

OPENAI_API_KEY=your_openai_api_key_here

# Optional settings (defaults shown)
MODEL_NAME=gpt-3.5-turbo
TEMPERATURE=0.7
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# HR Policy PDF — URL or local file path
HR_POLICY_PDF=https://www.nestle.com/sites/default/files/asset-library/documents/jobs/the_nestle_hr_policy_pdf_2012.pdf
